---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Lightbox from '../components/Lightbox.astro';
import { formatISODate } from '../utils/format';
import { getMetaDescription } from '../utils/excerpt';
import { site } from '../../site.config.mjs';

const {
  entry,
  Content,
  typeLabel,
  prev,
  next
} = Astro.props;

const tags = entry?.data?.tags ?? [];
const firstTag = tags[0];
const defaultImage = null;
const coverImage = entry?.data?.cover ?? null;
const ogImage = coverImage ?? defaultImage;
const description = getMetaDescription(entry);

---

<BaseLayout
  title={entry.data.title}
  description={description}
  image={ogImage}
  ogType="article"
  bodyClass="article-page immersive-page"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    {tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>
  <div class="article-header reader-exit-anchor">
    <h1 class="page-title">{entry.data.title}</h1>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="Exit reading mode"
      title="Exit reading mode"
      aria-hidden="true"
      tabindex="-1"
    >
      <Icon name="reader-exit" class="icon" />
    </button>
    <div class="meta-line">
      <span>{site.author}</span>
      <span aria-hidden="true">·</span>
      <span>{formatISODate(entry.data.date)}</span>
      {typeLabel ? <> · <span class="tag">{typeLabel}</span></> : null}
      {firstTag ? <> · <span class="tag">#{firstTag}</span></> : null}
    </div>
  </div>

  {coverImage ? (
    <figure class="article-cover">
      <img src={coverImage} alt="" loading="eager" decoding="async" />
    </figure>
  ) : null}

  <div class="prose">
    <Content />
  </div>
  {(prev || next) ? (
    <nav
      class:list={[
        'prev-next',
        !prev && next && 'prev-next--only-next',
        prev && !next && 'prev-next--only-prev'
      ]}
      aria-label="Previous and next posts"
    >
      {prev ? (
        <a class="prev-next__link prev-next__link--prev" href={prev.href} rel="prev">
          <span class="prev-next__label">Previous post</span>
          <span class="prev-next__title">{prev.title}</span>
        </a>
      ) : null}
      {next ? (
        <a class="prev-next__link prev-next__link--next" href={next.href} rel="next">
          <span class="prev-next__label">Next post</span>
          <span class="prev-next__title">{next.title}</span>
        </a>
      ) : null}
    </nav>
  ) : null}

  <Lightbox
    id="lightbox"
    label="Image preview"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initArticleLightbox } from '../scripts/lightbox';

    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });
  </script>
</BaseLayout>
