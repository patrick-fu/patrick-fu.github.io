---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import EssayCard from '../components/EssayCard.astro';
import { createWithBase, getEssaySlug, getVisibleEssays } from '../lib/content';
import { getFirstImage, getListExcerpt } from '../utils/excerpt';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const visibleEssays = await getVisibleEssays();
---

<BaseLayout title="Blog" bodyClass="essay-page">
  <div class="page-header page-header--essay page-header--with-search">
    <div class="page-heading">
      <h1 class="page-title">Blog</h1>
      <span class="page-subtitle">All posts, {visibleEssays.length} articles · <a href={withBase('/essay/rss.xml')}>RSS</a></span>
    </div>
    <div class="page-actions">
      <div class="entry-search" data-entry-search data-index-url={withBase('/essay/index.json')}>
        <div class="entry-search-panel" data-entry-search-panel aria-hidden="true">
          <input
            data-entry-search-input
            type="search"
            placeholder="Search title / excerpt / tags"
            autocomplete="off"
            aria-label="Search posts"
          />
        </div>
        <button
          class="entry-search-toggle"
          data-entry-search-toggle
          type="button"
          aria-label="Search posts"
          title="Search"
          aria-expanded="false"
        >
          <Icon name="search" class="icon" />
        </button>
      </div>
    </div>
  </div>
  <div class="entry-status" data-entry-search-status role="status" aria-live="polite"></div>

  <div class="list">
    {visibleEssays.map((entry) => (
      <EssayCard
        href={withBase(`/${getEssaySlug(entry)}/`)}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getListExcerpt(entry)}
        date={entry.data.date}
        tag={entry.data.tags?.[0]}
        badge={entry.data.badge}
        cover={entry.data.cover ?? getFirstImage(entry)}
      />
    ))}
  </div>

  <script>
    import '../scripts/entry-search.ts';
  </script>
</BaseLayout>
