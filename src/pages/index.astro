---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { createWithBase, getEssaySlug, getVisibleEssays } from '../lib/content';
import { getFirstImage, getListExcerpt } from '../utils/excerpt';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const visibleEssays = await getVisibleEssays();

const featuredSlugs = [
  '2026-03-24-spec-coding',
  '2026-03-01-voice-coding-ai-input',
  '2020-11-20-flutter-screen-capture',
  '2020-01-26-yuv-pixel-formats'
];

const essaysBySlug = new Map(visibleEssays.map((entry) => [getEssaySlug(entry), entry]));
const featuredEssays = featuredSlugs.map((slug) => {
  const entry = essaysBySlug.get(slug);
  if (!entry) {
    throw new Error(`Featured essay not found: ${slug}`);
  }
  return entry;
});
---

<BaseLayout title="Featured" bodyClass="essay-page">
  <div class="page-header page-header--essay">
    <div class="page-heading">
      <h1 class="page-title">Featured</h1>
      <span class="page-subtitle">Selected posts from Patrick's Blog</span>
    </div>
  </div>

  <div class="list">
    {featuredEssays.map((entry) => (
      <EssayCard
        href={withBase(`/${getEssaySlug(entry)}/`)}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getListExcerpt(entry)}
        date={entry.data.date}
        tag={entry.data.tags?.[0]}
        badge={entry.data.badge}
        cover={entry.data.cover ?? getFirstImage(entry)}
      />
    ))}
  </div>

  <nav class="pagination featured-more" aria-label="Featured posts">
    <div class="pagination__inner">
      <a class="pagination__link pagination__link--next" href={withBase('/essay/')}>View all posts</a>
    </div>
  </nav>
</BaseLayout>
