---
import { render } from 'astro:content';
import { getPublished, isReservedSlug } from '../lib/content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { createWithBase } from '../utils/format';

export async function getStaticPaths() {
  const base = import.meta.env.BASE_URL ?? '/';
  const withBase = createWithBase(base);
  const essays = await getPublished('essay', {
    orderBy: (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  });
  const visibleEssays = essays.filter((entry) => !isReservedSlug(entry.data.slug ?? entry.id));

  return visibleEssays.map((entry, index) => {
    const prevEntry = index > 0 ? visibleEssays[index - 1] : null;
    const nextEntry = index < visibleEssays.length - 1 ? visibleEssays[index + 1] : null;

    return {
      params: { slug: entry.data.slug ?? entry.id },
      props: {
        entry,
        prev: prevEntry
          ? { href: withBase(`/${prevEntry.data.slug ?? prevEntry.id}/`), title: prevEntry.data.title }
          : null,
        next: nextEntry
          ? { href: withBase(`/${nextEntry.data.slug ?? nextEntry.id}/`), title: nextEntry.data.title }
          : null
      }
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<ArticleLayout entry={entry} Content={Content} prev={prev} next={next} />
