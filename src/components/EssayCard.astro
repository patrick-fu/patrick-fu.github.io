---
import { formatISODate } from '../utils/format';
import TagLink from './TagLink.astro';

const {
  href,
  title,
  excerpt,
  date,
  tag,
  badge = 'Post',
  slug = '',
  cover,
  featured = false
} = Astro.props;

const displayBadge = badge?.trim() ? badge : 'Post';
---

<article
  class:list={['post-card', featured && 'post-card--featured']}
  data-entry-item
  data-slug={slug || undefined}
>
  <a class="post-card__media-link" href={href} aria-label={title}>
    <div class="post-card__media" aria-hidden="true">
      {cover ? (
        <img src={cover} alt="" loading="lazy" decoding="async" />
      ) : (
        <div class="post-card__placeholder">
          <span>{displayBadge}</span>
        </div>
      )}
    </div>
  </a>
  <div class="post-card__body">
    <div class="post-card__meta">
      <span>{formatISODate(date)}</span>
      {tag ? (
        <>
          <span aria-hidden="true">·</span>
          <TagLink tag={tag} />
        </>
      ) : null}
    </div>
    <h3 class="post-card__title">
      <a class="post-card__title-link" href={href}>{title}</a>
    </h3>
    {excerpt ? <p class="post-card__excerpt">{excerpt}</p> : null}
  </div>
</article>
