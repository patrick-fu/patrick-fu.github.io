---
import Icon from './Icon.astro';
import { createWithBase } from '../utils/format';

const { siteTitle = "Patrick's Blog" } = Astro.props;

const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const homeHref = withBase('/');
const logoSrc = withBase('/author/avatar.jpg');

const nav = [
  { label: 'Featured', href: withBase('/') },
  { label: 'Blog', href: withBase('/essay/') },
  { label: 'Archive', href: withBase('/archive/') },
  { label: 'About', href: withBase('/about/') }
];

---

<header class="site-header">
  <nav class="navbar" aria-label="Primary navigation">
    <a class="navbar-brand" href={homeHref} aria-label={`${siteTitle} home`}>
      <img class="navbar-brand__mark" src={logoSrc} alt="" width="38" height="38" decoding="async" />
      <span class="navbar-brand__text">{siteTitle}</span>
    </a>

    <input id="nav-toggle" class="nav-toggle" type="checkbox" aria-hidden="true" tabindex="-1" />
    <label class="nav-toggle-button nav-toggle-button--open" for="nav-toggle" aria-label="Open navigation">
      <span></span>
      <span></span>
      <span></span>
    </label>
    <label class="nav-toggle-button nav-toggle-button--close" for="nav-toggle" aria-label="Close navigation">
      <span></span>
      <span></span>
    </label>

    <ul class="nav" id="nav-menu">
      {nav.map((item) => {
        const isActive = pathname === item.href || (item.href !== homeHref && pathname.startsWith(item.href));
        return (
          <li>
            <a href={item.href} aria-current={isActive ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="navbar-actions">
      <a class="icon-button search-link" href={withBase('/essay/')} aria-label="Search posts" title="Search posts">
        <Icon name="search" class="icon" />
      </a>

      <button
        id="reader-toggle"
        class="icon-button reader-toggle"
        type="button"
        aria-label="Reading mode"
        aria-pressed="false"
        title="Reading mode"
      >
        <Icon name="book-open" class="icon icon-book-open" />
        <Icon name="book-closed" class="icon icon-book-closed" />
      </button>

      <a class="icon-button rss-link" href={withBase('/archive/rss.xml')} aria-label="RSS feed" title="RSS feed">
        <Icon name="rss" class="icon" />
      </a>

      <button
        id="theme-toggle"
        class="icon-button theme-toggle"
        type="button"
        aria-label="Dark mode"
        aria-pressed="false"
        title="Dark mode"
      >
        <Icon name="moon" class="icon icon-moon" />
        <Icon name="sun" class="icon icon-sun" />
      </button>
    </div>
  </nav>
</header>
